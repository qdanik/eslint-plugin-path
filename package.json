{
  "name": "eslint-plugin-path",
  "version": "3.0.0-rc.0",
  "main": "lib/index.js",
  "author": "qDanik <qdanik@yandex.ru>",
  "license": "MIT",
  "homepage": "https://github.com/qDanik/eslint-plugin-path#readme",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "absolute-path",
    "path",
    "relative-import"
  ],
  "files": [
    "lib/",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "npm@11.2.0",
  "repository": "qDanik/eslint-plugin-path",
  "scripts": {
    "format": "biome lint --write --unsafe && biome format --write && biome check --write --unsafe",
    "build": "rm -rf ./tsconfig.tsbuildinfo && tsc -b",
    "pretest": "npm run build",
    "type-check": "tsc --noEmit",
    "test": "jest --silent --runInBand",
    "test:coverage": "jest --silent --runInBand --coverage"
  },
  "dependencies": {
    "@typescript-eslint/types": "^8.57.0",
    "@typescript-eslint/utils": "^8.57.0",
    "load-tsconfig": "^0.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/eslint": "^9.6.1",
    "@types/estree": "^1.0.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/rule-tester": "^8.57.0",
    "eslint": "^10.0.3",
    "jest": "^30.3.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "eslint": ">=10.0.0"
  },
  "directories": {
    "docs": "docs"
  }
}
